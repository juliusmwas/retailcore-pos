generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Business {
  id        String    @id @default(uuid())
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  country   String?
  industry  String?
  phone     String?
  branches  Branch[]
  products  Product[]
  users     User[]
  sales     Sale[]
}

model Branch {
  id            String             @id @default(uuid())
  name          String
  location      String?
  businessId    String
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  code          String             @unique
  country       String?
  managerName   String?
  status        String             @default("ACTIVE")
  address       String?
  budget        Float              @default(0)
  city          String?
  currency      String?            @default("KES")
  initialStaff  Int                @default(0)
  managerEmail  String?
  managerPhone  String?
  maxStaff      Int                @default(20)
  openingDate   DateTime           @default(now())
  revenueTarget Float              @default(0)
  taxRegion     String?
  type          String?
  business      Business           @relation(fields: [businessId], references: [id])
  inventory     ProductInventory[]
  users         UserBranch[]
  sales     Sale[]
}

model User {
  id          String       @id @default(uuid())
  fullName    String
  email       String       @unique
  password    String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  businessId  String
  phone       String?
  staffNumber String?      @unique
  status      UserStatus   @default(ACTIVE)
  lastLogin    DateTime? // New fiel
  business    Business     @relation(fields: [businessId], references: [id])
  branches    UserBranch[]
  sales     Sale[]
}

model UserBranch {
  id        String   @id @default(uuid())
  userId    String
  branchId  String
  role      Role     @default(CASHIER)
  createdAt DateTime @default(now())
  branch    Branch   @relation(fields: [branchId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, branchId])
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  products  Product[]
}

model Product {
  id           String             @id @default(uuid())
  name         String
  sku          String             @unique
  barcode      String             @unique
  brand        String?
  uom          String             @default("Pcs")
  subCategory  String?
  costPrice    Float
  sellingPrice Float
  markup       Float
  taxClass     String             @default("Standard 16%")
  categoryId   String
  businessId   String
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  business     Business           @relation(fields: [businessId], references: [id])
  category     Category           @relation(fields: [categoryId], references: [id])
  inventory    ProductInventory[]
  sales     SaleItem[]

  @@index([sku, barcode])
}

model ProductInventory {
  id        String   @id @default(uuid())
  stock     Int      @default(0)
  minStock  Int      @default(5)
  productId String
  branchId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  branch    Branch   @relation(fields: [branchId], references: [id])
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, branchId])
}

enum Role {
  OWNER
  ADMIN
  CASHIER
  MANAGER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model Sale {
  id              String       @id @default(uuid())
  invoiceNo       String       @unique // e.g., INV-1001
  
  // Financials
  subTotal        Float        @default(0)
  taxAmount       Float        @default(0)
  discount        Float        @default(0)
  totalAmount     Float        @default(0)
  
  // Payment Info
  paymentMethod   PaymentMethod @default(CASH)
  status          SaleStatus    @default(COMPLETED)
  
  // Tracking
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // Relationships
  businessId      String
  branchId        String
  userId          String        // The cashier who made the sale
  customerId      String?       // Optional link to a customer
  
  business        Business      @relation(fields: [businessId], references: [id])
  branch          Branch        @relation(fields: [branchId], references: [id])
  user            User          @relation(fields: [userId], references: [id])
  items           SaleItem[]    // The specific products sold

  @@index([businessId, branchId, createdAt])
}

model SaleItem {
  id          String   @id @default(uuid())
  saleId      String
  productId   String
  quantity    Int
  unitPrice   Float
  totalPrice  Float    // (quantity * unitPrice)
  
  sale        Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id])
}

enum PaymentMethod {
  CASH
  MPESA
  CARD
  CREDIT
}

enum SaleStatus {
  COMPLETED
  PENDING
  CANCELLED
  REFUNDED
}
